---
import '../styles/global.css'

const {
  title = 'Lestari Las | Pagar, Canopy, Railing, dan Pintu Garasi',
  description = 'Bengkel Las Lestari melayani pagar, canopy, railing, pintu garasi, dan fabrikasi. Titik workshop tersedia lewat Google Maps dengan patokan Jln Jombang Ciledug, depan Ruko Emerald Bintaro No. 7.',
} = Astro.props

const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/x-icon" href={`${basePath}favicon.ico`} />
    <link rel="shortcut icon" href={`${basePath}favicon.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f1216" />
    <script is:inline>
      ;(function (w, d, s, l, i) {
        w[l] = w[l] || []
        w[l].push({
          'gtm.start': new Date().getTime(),
          event: 'gtm.js',
        })
        const f = d.getElementsByTagName(s)[0]
        const j = d.createElement(s)
        const dl = l !== 'dataLayer' ? `&l=${l}` : ''

        j.async = true
        j.src = `https://www.googletagmanager.com/gtm.js?id=${i}${dl}`
        f.parentNode.insertBefore(j, f)
      })(window, document, 'script', 'dataLayer', 'GTM-NMPMKH3T')
    </script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18022266763"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'AW-18022266763');
    </script>
    <title>{title}</title>
  </head>
  <body>
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-NMPMKH3T"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>

    <slot />

    <script is:inline>
      (() => {
        const revealElements = document.querySelectorAll('[data-reveal]')

        if (!revealElements.length) {
          return
        }

        const showAll = () => {
          revealElements.forEach((element) => element.classList.add('is-visible'))
        }

        if (
          window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
          !('IntersectionObserver' in window)
        ) {
          showAll()
          return
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible')
                observer.unobserve(entry.target)
              }
            })
          },
          {
            threshold: 0.18,
            rootMargin: '0px 0px -50px 0px',
          },
        )

        revealElements.forEach((element) => observer.observe(element))
      })()
    </script>

    <script is:inline>
      (() => {
        const whatsappLinks = document.querySelectorAll('[data-track-whatsapp]')

        if (!whatsappLinks.length) {
          return
        }

        whatsappLinks.forEach((link) => {
          link.addEventListener('click', () => {
            // Pengiriman via GTM (opsi 1)
            window.dataLayer = window.dataLayer || []
            window.dataLayer.push({
              event: 'whatsapp_click',
              whatsapp_url: link.href,
              whatsapp_text: link.textContent?.trim() || 'WhatsApp CTA',
              whatsapp_placement: link.dataset.whatsappPlacement || 'unknown',
            })

            // Pengiriman via gtag.js langsung (opsi 2 - Google Ads Konversi 'Contact')
            if (typeof window.gtag === 'function') {
              window.gtag('event', 'conversion', {
                'send_to': 'AW-18022266763/RWKNCKf4sZQcEIvv15FD',
                'value': 1.0,
                'currency': 'IDR'
              })
            }
          })
        })
      })()
    </script>
  </body>
</html>
